            {
              "message": "=You are a resume parser. Return ONLY valid JSON, no markdown, no explanation. \n{   \n\"full_name\": \"string\",   \n\"email\": \"string or null\",  \n\"phone\": \"string or null\",   \n\"location\": \"string or null\",   \n\"skills\": [\"string\"],   \n\"years_experience\": \"number or null\",   \n\"work_experience\": [{\"company\":\"string\",\"title\":\"string\",\"start_date\":\"string\",\"end_date\":\"string\"}],   \"education\": [{\"institution\":\"string\",\"degree\":\"string\",\"field\":\"string or null\",\"graduation_year\":\"number or null\"}],   \"certifications\": [{\"name\":\"string\",\"issuer\":\"string or null\"}],   \"languages\": [{\"language\":\"string\",\"proficiency\":\"string or null\"}] \n}"
            }
          ]
        },
