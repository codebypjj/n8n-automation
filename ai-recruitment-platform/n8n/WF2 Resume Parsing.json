    {
      "parameters": {
        "jsCode": "const rawText = $input.first().json.text\n  .replace(/\\x00/g, '')\n  .replace(/[ \\t]+/g, ' ')\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .slice(0, 12000);\n\nreturn [{\n  json: {\n    candidate_id:   $('Webhook').first().json.body.candidate_id,\n    application_id: $('Webhook').first().json.body.application_id,\n    job_id:         $('Webhook').first().json.body.job_id,\n    raw_text:       rawText,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        32,
        32
      ],
      "id": "d8e52247-8194-4e43-adbb-3474dac27daa",
      "name": "Clean Text"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json.text;\n\n// Remove markdown fences if present\nconst clean = response\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .replace(/\\\\n/g, ' ')\n  .trim();\n\n// Parse JSON\nlet parsed;\ntry {\n  parsed = JSON.parse(clean);\n} catch(e) {\n  throw new Error('Failed to parse Groq response: ' + e.message);\n}\n\n// Validate required field\nif (!parsed.full_name) throw new Error('full_name missing');\n\n// Deduplicate and clean skills\nif (parsed.skills) {\n  parsed.skills = [...new Set(\n    parsed.skills.map(s => s.toLowerCase().trim())\n  )];\n}\n\nreturn [{\n  json: {\n    candidate_id:   $('Webhook').first().json.body.candidate_id,\n    application_id: $('Webhook').first().json.body.application_id,\n    job_id:         $('Webhook').first().json.body.job_id,\n    parsed_resume:  parsed,\n    raw_text:       $('Clean Text').first().json.raw_text,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
