    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst RATES = {\n  'Tarpaulin':          { material: 80,   minCharge: 500  },\n  'Acrylic Sign':       { material: 650,  minCharge: 2000 },\n  'Lighted Sign (LED)': { material: 2500, minCharge: 8000 },\n  'Sticker Printing':   { material: 120,  minCharge: 300  },\n  'Panaflex':           { material: 180,  minCharge: 1200 },\n  'Billboard':          { material: 95,   minCharge: 5000 },\n  'Custom Request':     { material: 200,  minCharge: 1000 },\n};\n\nconst type = item.signageType || 'Tarpaulin';\nconst w = parseFloat(item.width) || 1;\nconst h = parseFloat(item.height) || 1;\nconst qty = parseInt(item.quantity) || 1;\nconst sqm = w * h;\nconst rate = RATES[type] || { material: 200, minCharge: 1000 };\n\nlet materialCost = Math.max(sqm * rate.material * qty, rate.minCharge);\nlet laborCost = sqm * 150 * qty;\nif (qty > 10) laborCost *= 0.75;\nelse if (qty > 5) laborCost *= 0.85;\n\nconst targetDate = new Date(item.targetDate);\nconst today = new Date();\nconst daysUntil = Math.ceil((targetDate - today) / 86400000);\nlet rushMultiplier = 1;\nif (daysUntil <= 1) rushMultiplier = 1.50;\nelse if (daysUntil <= 3) rushMultiplier = 1.30;\n\nlet installationCost = 0;\nif (item.installationRequired === 'Yes') {\n  installationCost = 1200;\n}\n\nconst deliveryCost = installationCost > 0 ? 0 : 350;\nconst subtotal = (materialCost + laborCost) * rushMultiplier;\nconst totalAmount = subtotal + installationCost + deliveryCost;\n\nconst productionDays = type.includes('Lighted') ? 7 :\n  type.includes('Acrylic') ? 5 :\n  qty > 10 ? 4 : 2;\nconst installationDays = installationCost > 0 ? 1 : 0;\n\nreturn [{\n  json: {\n    ...item,\n    materialCost: Math.round(materialCost),\n    laborCost: Math.round(laborCost),\n    installationCost: Math.round(installationCost),\n    deliveryCost: Math.round(deliveryCost),\n    subtotal: Math.round(subtotal),\n    totalAmount: Math.round(totalAmount),\n    rushMultiplier,\n    productionDays,\n    installationDays,\n    estimatedCompletionDate: new Date(Date.now() + (productionDays + installationDays) * 86400000).toISOString().slice(0,10),\n  }\n}];"
      },
