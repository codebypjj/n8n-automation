      "parameters": {
        "jsCode": "const aiText = $input.first().json.output;\nconst cleaned = aiText.replace(/```json|```/g, '').trim();\nconst aiData = JSON.parse(cleaned);\n\nconst prev = $input.first().json;\n\nreturn [{\n  json: {\n    ...prev,\n    projectSummary: aiData.projectSummary,\n    missingInfo: aiData.missingInfo.join(', '),\n    complexity: aiData.complexity,\n    productionNotes: aiData.productionNotes,\n    installerNotes: aiData.installerNotes,\n    riskFlags: aiData.riskFlags.join(', '),\n    estimatedDays: aiData.estimatedDays,\n    urgencyLevel: aiData.urgencyLevel,\n    recommendedMaterial: aiData.recommendedMaterial,\n  }\n}];"
      },
