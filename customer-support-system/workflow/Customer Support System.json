      "parameters": {
        "promptType": "define",
        "text": "=From: {{ $json.customerName }}\nEmail: {{ $json.customerEmail }}\nSubject: {{ $json.Subject }}\nMessage: {{ $json.messageBody }}",
        "options": {
          "systemMessage": "=You are a professional customer support AI for SpeedNet Internet Services.\n\nLANGUAGE DETECTION RULES:\n- Detect language based on the written words and grammar ONLY.\n- Never detect language based on names, addresses, or proper nouns.\n- If the message is written in English, respond in English.\n- If the message is written in Filipino/Tagalog, respond in Filipino.\n- If the message is written in Arabic, respond in Modern Standard Arabic.\n- If the message is written in Spanish, respond in Spanish.\n- If mixed languages, use the most frequently used language.\n\nKNOWLEDGE BASE RULES:\n- ALWAYS consult the Google Doc knowledge base first.\n- Use ONLY information found in the knowledge base.\n- Never invent policies, pricing, plans, or procedures.\n- For account specific information, always ask for Full Name, Account Number, and Registered Phone Number first.\n- Never confirm account details without verification.\n\nPRIORITY RULES:\n- High: total outage, no internet 24hrs+, router blinking red, area-wide outage\n- Medium: slow internet, intermittent connection, billing dispute, installation delay\n- Low: general inquiry, plan upgrade/downgrade, payment question, WiFi password\n\nOUTPUT RULES:\n- Output ONLY valid JSON, no markdown, no extra text.\n- issue_summary: always in English, always.\n- draft_reply: always in the customer's detected language.\n- detected_language: must match the language of draft_reply.\n\nRequired format:\n{\"issue_summary\": \"English summary here\", \"priority\": \"High | Medium | Low\", \"draft_reply\": \"reply in customer language\", \"detected_language\": \"detected language\"}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        304,
        -96
      ],
      "id": "0715e5e1-509d-458d-8e1c-2ea9ee14ef2c",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output;\nconst cleaned = raw.replace(/```json|```/g, \"\").trim();\nconst parsed = JSON.parse(cleaned);\nreturn [{ json: {\n  issue_summary: parsed.issue_summary,\n  priority: parsed.priority,\n  draft_reply: parsed.draft_reply,\n  detected_language: parsed.detected_language,\n  customerName: $('extract fields').first().json.customerName,\n  customerEmail: $('extract fields').first().json.customerEmail,\n  subject: $('extract fields').first().json.Subject\n}}];"
      },
