    {
      "parameters": {
        "jsCode": "const formData = $('review form').first().json;\nconst ticketData = $('get ticket').first().json;\n\nconst humanEdit = formData['Your Reply (leave blank to approve)'] || '';\nconst aiDraft = ticketData.fields['AI Draft Reply'] || '';\nconst customerEmail = ticketData.fields['Customer Email'] || '';\nconst subject = ticketData.fields['Subject'] || '';\nconst recordId = formData['Airtable Record ID'];\n\nconst finalReply = humanEdit.trim() !== ''\n  ? humanEdit.trim()\n  : aiDraft.trim();\n\nreturn [{ json: {\n  finalReply: finalReply,\n  customerEmail: customerEmail,\n  subject: subject,\n  recordId: recordId,\n  wasEdited: humanEdit.trim() !== ''\n}}];"
      },
