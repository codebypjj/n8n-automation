      "parameters": {
        "jsCode": "const response = $input.first().json.message.content;\n\nreturn [{\n  json: {\n    fileId:       trigger.id,\n    fileName:     trigger.name,\n    mimeType:     trigger.mimeType,\n    driveLink:    trigger.webViewLink,\n    uploadTime:   trigger.createdTime,\n    startTime:    Date.now()\n  }\n}];"
