        "responses": {
          "values": [
            {
              "content": "=Based on this video transcript, generate optimized YouTube Shorts content.\n\nTRANSCRIPT:\n{{ $json.transcript }}\n\nReturn ONLY a valid JSON object with exactly these fields, no extra text:\n{\n  \"title\": \"max 60 characters, punchy and curiosity-driven\",\n  \"description\": \"2-3 sentences, engaging, ends with a call to action\",\n  \"hashtags\": [\"tag1\", \"tag2\", \"tag3\"],\n  \"hookSentence\": \"max 8 words shown in first 3 seconds of video\",\n  \"hookType\": \"question or statement\"\n}\n\nRULES:\n- Title must start with a number, question, or bold statement\n- Hook must create urgency or curiosity\n- Always include Shorts in the hashtags array\n- Description must end with: Follow for more tips!"
            },
            {
              "role": "system",
              "content": "You are an expert YouTube Shorts content strategist who specializes in viral short-form video content. You understand social media algorithms, trending formats, and audience psychology. You always respond with valid JSON only — no markdown, no extra text, no code blocks."
            }
          ]
        },
