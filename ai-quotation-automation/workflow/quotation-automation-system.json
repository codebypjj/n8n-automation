    {
      "parameters": {
        "sendTo": "={{ $('Data Normalization').item.json.email }}",
        "subject": "=Your Quotation Request — {{ $json['Inquiry ID'] }} {{ $json['Service Requested'] }}",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"font-family: Arial, sans-serif; max-width: 650px; margin: auto; color: #333;\">\n\n  <div style=\"background: #1a73e8; padding: 24px; text-align: center;\">\n    <h1 style=\"color: white; margin: 0;\">Your Business Name</h1>\n    <p style=\"color: #cce5ff; margin: 4px 0;\">Quotation Reference: {{ $json['Inquiry ID'] }}</p>\n  </div>\n\n  <div style=\"padding: 32px 24px;\">\n    <p>Hi <strong>{{ $json['Full Name'] }}</strong>,</p>\n\n    <p>Thank you for reaching out! We've received your project inquiry and our team has reviewed your requirements. Below is a preliminary quotation based on the information you provided.</p>\n\n    <hr style=\"border: none; border-top: 1px solid #eee; margin: 24px 0;\">\n\n    <h2 style=\"color: #1a73e8;\">📋 Project Summary</h2>\n    <p>{{ $json['AI Project Summary'] }}</p>\n\n    <h2 style=\"color: #1a73e8;\">📦 Recommended Deliverables</h2>\n    <p>{{ $('Parse JSON Output').item.json.recommendedDeliverables }}</p>\n\n    <h2 style=\"color: #1a73e8;\">💰 Estimated Investment</h2>\n    <p style=\"font-size: 18px; font-weight: bold; color: #333;\">{{ $('Parse JSON Output').item.json.estimatedPriceRange }}</p>\n    <p><em>Note: This is a preliminary estimate. Final pricing will be confirmed after a detailed project discussion.</em></p>\n\n    <h2 style=\"color: #1a73e8;\">⏱ Estimated Timeline</h2>\n    <p>{{ $('Parse JSON Output').item.json.estimatedDuration }}</p>\n\n    <hr style=\"border: none; border-top: 1px solid #eee; margin: 24px 0;\">\n\n    <h2 style=\"color: #1a73e8;\">📝 Quotation Details</h2>\n    <div style=\"background: #f8f9fa; padding: 20px; border-radius: 8px; white-space: pre-line;\">{{ $('Parse JSON Output').item.json.quotationDraft }}</div>\n\n    <hr style=\"border: none; border-top: 1px solid #eee; margin: 24px 0;\">\n\n    <h2 style=\"color: #1a73e8;\">✅ Next Steps</h2>\n    <ol>\n      <li>Review this preliminary quotation</li>\n      <li>Reply to this email with any questions or clarifications</li>\n      <li>Schedule a free consultation call with our team</li>\n      <li>We'll send you a formal, finalized proposal</li>\n    </ol>\n\n    <div style=\"background: #e8f0fe; padding: 16px; border-radius: 8px; margin-top: 24px;\">\n      <p style=\"margin: 0;\"><strong>Ready to proceed?</strong> Simply reply to this email or call us at <strong>+63 XXX XXX XXXX</strong>. We'd love to work with you!</p>\n    </div>\n\n    <p style=\"margin-top: 32px;\">Warm regards,<br>\n    <strong>Your Name</strong><br>\n    Your Business Name<br>\n    your@email.com | +63 XXX XXX XXXX</p>\n  </div>\n\n  <div style=\"background: #f1f3f4; padding: 16px; text-align: center; font-size: 12px; color: #777;\">\n    <p>This is an automated quotation estimate. All prices and timelines are subject to confirmation.</p>\n    <p>© 2024 Your Business Name. All rights reserved.</p>\n  </div>\n\n</body>\n</html>",
        "options": {}
